# Isaac — Beispiel-Konfiguration (kopiere nach .env)
# In GitHub Codespaces: GROQ_API_KEY als User/Repo-Secret setzen, nicht hier eintragen.

ISAAC_OWNER=Steffen

# Provider: groq (empfohlen in Codespaces), openrouter, ollama (nur lokal)
ACTIVE_PROVIDER=groq

# Groq — kostenloser Tier: https://console.groq.com
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant

# OpenRouter (primäres Multi-Model-Gateway)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=meta-llama/llama-3.2-3b-instruct:free

# Google AI Studio / Gemini (https://aistudio.google.com/apikey)
# ACTIVE_PROVIDER=gemini  # optional: Gemini als Primary
GOOGLE_API_KEY=
# GEMINI_API_KEY=          # Alias; wird genutzt wenn GOOGLE_API_KEY leer
GEMINI_MODEL=gemini-flash-lite-latest
# GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/models
# Ensemble: mehrere Modelle vergleichen/kombinieren (ensemble: …)
ISAAC_ENSEMBLE=1
ISAAC_ENSEMBLE_FREE_ONLY=1
ISAAC_ENSEMBLE_N=3
ISAAC_ENSEMBLE_STAGGER_MS=800
ISAAC_ENSEMBLE_JUDGE=1
# Always-on nur bei schweren CHAT-Fragen (nicht Tools/Greetings)
ISAAC_ENSEMBLE_AUTO=1
ISAAC_ENSEMBLE_AUTO_MIN_WORDS=22
# OPENROUTER_ENSEMBLE_MODELS=meta-llama/llama-3.2-3b-instruct:free,google/gemma-2-9b-it:free

# Ollama (nur lokal / Termux — in Codespaces nicht verfügbar)
OLLAMA_HOST=http://127.0.0.1:11434
OLLAMA_MODEL=qwen2.5:1.5b
OLLAMA_TIMEOUT=300

# Lokales OpenAI-kompatibles Backend (LM Studio / vLLM / SGLang / llama.cpp / LocalAI)
# Docs: docs/LOCAL_LLM.md
# Kernel: ACTIVE_PROVIDER=local  |  base_url MUSS die volle Completions-URL sein
#   (…/v1/chat/completions), nicht nur …/v1  |  MODEL = exakter Server-Name
# ACTIVE_PROVIDER=local
LOCAL_LLM_ENABLED=1
# LM Studio default:
LOCAL_LLM_BASE_URL=http://127.0.0.1:1234/v1/chat/completions
# vLLM typisch:   http://127.0.0.1:8000/v1/chat/completions
# SGLang typisch: http://127.0.0.1:30000/v1/chat/completions
LOCAL_LLM_MODEL=local-model
# LOCAL_LLM_API_KEY=          # optional; die meisten lokalen Server brauchen keinen Key
# LOCAL_LLM_TIMEOUT=180

# Monitor / Dashboard
MONITOR_PORT=8765
DASHBOARD_PORT=8766
MONITOR_HTTP_PORT=8766

# Free online (Render / HF Spaces / Fly free) — zero GCP billing
# Docs: docs/FREE_HOSTING.md  |  bash scripts/run_free_cloud.sh
# ISAAC_FREE_CLOUD=1
# ISAAC_UNIFIED_PORT=1          # HTTP + WS on one port: /ws
# ISAAC_BIND_HOST=0.0.0.0
# PORT=7860                    # PaaS sets this

# Vektor-Gedächtnis (ChromaDB): 0=aktiv (braucht: pip install chromadb)
# CI/low-resource: 1=aus. Runtime: ISAAC_DISABLE_VECTOR_MEMORY=0 in .env
ISAAC_DISABLE_VECTOR_MEMORY=1

# Privilege-Modus für lokale Geräte:
# - "user"   : Standard-Sicherheitsmode (Standard)
# - "admin"  : Vollständiger Zugriff wie Owner, keine Gating-Fragen (für Android/lokale Geräte)
ISAAC_PRIVILEGE_MODE=user

# ── Optional Sentry AI Agent Monitoring ─────────────────────────────────────
# Tracks LLM calls (relay), token estimates, latency, Conversations view.
# Leave SENTRY_DSN empty to keep monitoring fully off (local default).
# SENTRY_DSN=https://<key>@o<orgId>.ingest.sentry.io/<projectId>
# SENTRY_TRACES_SAMPLE_RATE=1.0   # default: 1.0 development, 0.1 production
# SENTRY_ENVIRONMENT=development
# SENTRY_RELEASE=isaac@5.3
# SENTRY_INCLUDE_PROMPTS=1   # 1=send prompts/outputs (PII); 0=metadata only

# ── Optional External Memory (default OFF — CI-safe) ─────────────────────────
# Install: bash scripts/install_external_memory.sh
# Packages: requirements-memory-extra.txt + npm i -g @letta-ai/letta-code
# ISAAC_MEM0_ENABLED=0
# ISAAC_COGNEE_ENABLED=0
# ISAAC_LETTA_ENABLED=0
# ISAAC_OPEN_INTERPRETER_ENABLED=0
# Grok Build Agent companion (headless CLI; needs XAI_API_KEY or grok login)
# Docs: docs/GROK_AGENT.md
# ISAAC_GROK_AGENT_ENABLED=0
# Isaac wählt Companion-Agenten selbst (nur bei CODE/FILE/AGENT/RESEARCH + Markern):
# ISAAC_AGENT_AUTO_SELECT=1
# ISAAC_AGENT_TIMEOUT=180
# ISAAC_AGENT_PRIMARY=0   # 1 = Agent-Antwort primär (experimentell)
# GROK_BIN=grok
# ISAAC_GROK_AGENT_MODEL=
# ISAAC_GROK_AGENT_CWD=
# ISAAC_GROK_AGENT_TIMEOUT=300
# ISAAC_GROK_AGENT_MAX_TURNS=20
# ISAAC_GROK_AGENT_ALWAYS_APPROVE=0   # 1 = --always-approve (trusted env only)
# ISAAC_GROK_AGENT_SAFE_YOLO=1        # deny+rules when always_approve
# ISAAC_GROK_AGENT_AUTO_RESUME=1      # next grok: resumes last session
# ISAAC_GROK_AGENT_DISALLOWED_TOOLS=  # e.g. run_terminal_cmd,web_search
# ISAAC_GROK_AGENT_RULES=
# ISAAC_GROK_AGENT_EXTRA_DENY=        # extra --deny rules, comma-separated
# XAI_API_KEY=
# ISAAC_EXTERNAL_MEMORY_WRITE=0
# ISAAC_EXTERNAL_MEMORY_MIN_SCORE=5.0
# ISAAC_EXTERNAL_MEMORY_SEARCH_TIMEOUT=2.5
# Cloud recommended: ISAAC_EXTERNAL_MEMORY_SEARCH_TIMEOUT=15
# Cloud recommended: ISAAC_EXTERNAL_MEMORY_WRITE_TIMEOUT=30
# ISAAC_MEM0_ALLOW_CLOUD=0
# ISAAC_COGNEE_ALLOW_CLOUD=0
# Cognee Cloud (tenant URL from API Keys page; header X-Api-Key):
# COGNEE_BASE_URL=https://your-tenant.aws.cognee.ai
# COGNEE_API_KEY=
# LETTA_BIN=letta
# Open Interpreter companion (Codex harness CLI; needs OPENROUTER_API_KEY or valid OpenAI key)
# Docs: docs/OPEN_INTERPRETER.md
# OPEN_INTERPRETER_BIN=interpreter
# ISAAC_OPEN_INTERPRETER_SANDBOX=read-only
# ISAAC_OPEN_INTERPRETER_PROVIDER=openrouter
# ISAAC_OPEN_INTERPRETER_MODEL=openai/gpt-4o-mini
# ISAAC_OPEN_INTERPRETER_TIMEOUT=180
# Explicit commands: "external memory" | "letta: <task>" | "oi: <task>" | "grok: <task>" | "cognee status"

# Web monorepo Sentry (Next.js project isaac-web) — set in web/apps/*/.env.local
# NEXT_PUBLIC_SENTRY_DSN=
# SENTRY_ORG=evo20
# SENTRY_PROJECT=isaac-web

# ── Secrets bootstrap (local only — never commit real values) ───────────────
# bash scripts/export_cli_auth.sh   → data/cli_auth_backup/ (gitignored)
# Docs: docs/CONNECTIONS_AND_SECRETS.md
# ISAAC_TOOL_BRIDGE_ENABLED=1
# GITHUB_TOKEN=                    # or GH_TOKEN — GitHub bridge tool
# GH_TOKEN=
